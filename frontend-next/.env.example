# ═══════════════════════════════════════════════════
# Application Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit your actual .env.local file!
# ═══════════════════════════════════════════════════

# ── SUPABASE (Frontend + Server Routes) ───────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── SUPABASE ADMIN (Backend Action Routes ONLY) ───
# Required for Next.js to bypass Row Level Security when confirming orders & handling status
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── STRIPE PAYMENTS ─────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_signing_secret_here

# ── APP CONFIG ──────────────────────────────────
# Optional: Next.js will use localhost:3000 automatically locally.
# Define this on production to handle proper absolute URLs if necessary.
# FRONTEND_URL=https://socialfootholds.netlify.app
